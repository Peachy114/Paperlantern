{
  "name": "paperlantern",
  "private": true,
  "scripts": {
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "client:lint": "npm --prefix client run lint",
    "client:preview": "npm --prefix client run preview",
    "server:dev": "composer --working-dir=server dev",
    "server:serve": "cd server && php artisan serve",
    "server:migrate": "cd server && php artisan migrate",
    "server:test": "composer --working-dir=server test",
    "build": "npm run client:build",
    "lint": "npm run client:lint",
    "test": "npm run server:test"
  }
}

